# Database
DB_URL=jdbc:postgresql://localhost:5432/localpro_dev
DB_USER=localpro
DB_PASS=localpro

# Firebase (download from Firebase Console → Project Settings → Service Accounts → Generate new private key)
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Cloudinary (from cloudinary.com → Dashboard → copy the URL)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Server
SERVER_PORT=8080
